# Archera
alias login='login-ops'
alias login-admin='aws-login-mfa archera-admin'
alias login-dev='aws-login-mfa archera-developer'
alias login-ops='aws-login-mfa archera-operations'
alias login-ro='aws-login-mfa archera-readonly'
alias archera-export='archera-ops'
alias archera-admin='aws-export archera-admin'
alias archera-dev='aws-export archera-developer'
alias archera-ops='aws-export archera-operations'
alias archera-ro='aws-export archera-readonly'
alias staging='API_URL=http://localhost:5002 make start'
alias production='API_URL=http://localhost:5003 make start'

# Github
alias commit='git commit -m'
alias commits='git log --pretty=oneline | head -n'
alias fetch='git pull && git fetch -p'
alias push='git push'

# Change Directory
alias blog='cd ~/Code/personal-projects/nwcalvank.dev/'
alias code='cd ~/Code/$PRIMARY_PROJECT'
alias dev='cd ~/Code/development-environment/'
alias lab='cd ~/Code/homelab/'
alias work='cd ~/Code/archera/reserved-ai/server && archera'
